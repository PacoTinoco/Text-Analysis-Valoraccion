# ── EvalPlatform – Environment Variables ──────────────────────────────────────
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ── Supabase ──────────────────────────────────────────────────────────────────
# Get these from: https://supabase.com/dashboard → your project → Settings → API

# Used by the Python API (server-side, service role)
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_KEY=your-service-role-key-here

# Used by the Next.js frontend (client-side, anon key)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# ── Anthropic (AI summaries) ───────────────────────────────────────────────────
# Get your key from: https://console.anthropic.com/
# Leave blank to disable AI summaries (Ollama will be tried first anyway)
ANTHROPIC_API_KEY=sk-ant-...

# ── API settings ──────────────────────────────────────────────────────────────
MAX_FILE_SIZE_MB=100

# ── Redis cache ────────────────────────────────────────────────────────────────
# Leave empty to use the in-memory fallback (fine for local dev without Docker).
# Docker Compose sets this automatically to redis://redis:6379/0.
# For AWS, point this at your ElastiCache endpoint.
REDIS_URL=

# ── AWS S3 file storage ────────────────────────────────────────────────────────
# Leave all empty to use local disk storage (fine for dev and single-server deploy).
# For AWS (ECS / multi-container): create an S3 bucket and IAM user with
# s3:PutObject, s3:GetObject, s3:HeadBucket permissions, then fill these in.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_S3_BUCKET=

# ── Frontend – Public API URL ──────────────────────────────────────────────────
# URL the BROWSER uses to reach the API.
# Local dev:               http://localhost:8000
# Docker Compose (local):  http://localhost:8000
# Production with Nginx:   http://your-server-ip-or-domain  (port 80, no :8000)
NEXT_PUBLIC_API_URL=http://localhost:8000
